# Copy to .env and fill in for signed + notarized releases (Scripts/release.sh).
# Create the keychain profile once:
#   xcrun notarytool store-credentials "$NOTARY_PROFILE" \
#     --key "$NOTARY_KEY_PATH" --key-id "$NOTARY_KEY_ID" --issuer "$NOTARY_ISSUER"
# Issuer ID + keys: App Store Connect → Users and Access → Integrations → Keys.
NOTARY_PROFILE=temple-notary
NOTARY_KEY_PATH=~/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
NOTARY_KEY_ID=XXXXXXXXXX
NOTARY_ISSUER=00000000-0000-0000-0000-000000000000
APPLE_TEAM_ID=XXXXXXXXXX
